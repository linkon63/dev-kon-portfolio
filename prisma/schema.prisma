generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// Portfolio content — replaces the former Firestore collections.

model Blog {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String
  content       String?   @db.Text
  image         String
  date          String
  href          String?
  active        Boolean   @default(true)
  likes         Int       @default(0)
  allowLikes    Boolean   @default(true)
  allowComments Boolean   @default(true)
  createdAt     DateTime  @default(now())
  comments      Comment[]

  @@index([createdAt])
}

model Project {
  id        String   @id @default(cuid())
  title     String
  text      String
  image     String
  liveUrl   String?
  clientUrl String?
  serverUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  name      String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Service {
  id        String   @id @default(cuid())
  title     String
  tags      String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// "About" homepage section. Single editable row (newest active row wins).
model About {
  id        String   @id @default(cuid())
  greeting  String   @default("Hey")
  intro     String   @db.Text
  bio1      String   @db.Text
  bio2      String   @db.Text
  image     String   @default("")
  ctaText   String   @default("Get in touch")
  ctaHref   String   @default("#contact")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// "Experience" timeline entries. `links` holds project links as
// [{ label, url }]; `order` controls display order (ascending, newest first).
model Experience {
  id         String   @id @default(cuid())
  role       String
  company    String
  companyUrl String?
  location   String
  period     String
  duration   String?
  current    Boolean  @default(false)
  highlights String[]
  stack      String[]
  links      Json?
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// "Let's talk" contact form submissions.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  project   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Single-row site settings (id is always "site").
model SiteSettings {
  id         String  @id @default("site")
  resumeUrl  String?
  resumeName String?
}

// First-party analytics events (powers the admin dashboard).
model AnalyticsEvent {
  id       String   @id @default(cuid())
  type     String
  path     String
  visitor  String
  device   String
  browser  String
  referrer String
  lang     String
  ts       DateTime @default(now())

  @@index([ts])
}

// Uploaded files (project/blog images, resume PDF) stored in Postgres and
// served via /api/uploads/[id]. Replaces Firebase Storage.
model Upload {
  id          String   @id @default(cuid())
  folder      String
  filename    String
  contentType String
  data        Bytes
  createdAt   DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  blogId    String
  name      String
  email     String
  content   String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())

  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([blogId])
  @@index([parentId])
}
