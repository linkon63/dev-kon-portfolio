# Copy to .env (or .env.local) and fill in. `.env*` is git-ignored.

# --- Database (Prisma Postgres) ---
# Connection string for Prisma. Written automatically by `prisma postgres link`.
DATABASE_URL=

# --- Admin panel (server-side; NOT exposed to the browser) ---
# Credentials checked by /api/admin/login. Defaults exist for the demo, but set
# real values in production.
ADMIN_EMAIL=admin@devkon.com
ADMIN_PASSWORD=devkon2026
# Secret used to sign the admin session cookie. Use a long random string in prod.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# --- Login screen hint (public, display only) ---
# Shown on the admin login page as the demo credentials. Safe to expose.
NEXT_PUBLIC_ADMIN_EMAIL=admin@devkon.com
NEXT_PUBLIC_ADMIN_PASSWORD=devkon2026

# --- Contact form email (Resend) ---
# The "Let's talk" form stores submissions in the DB and emails them via Resend.
RESEND_API_KEY=
# Where enquiries are delivered (defaults to the site owner's address in code).
CONTACT_TO_EMAIL=
# Verified sender. Use "onboarding@resend.dev" until you verify a domain.
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
