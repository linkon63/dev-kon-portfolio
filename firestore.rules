rules_version = '2';

// ⚠️ DEMO RULES — the admin panel uses a client-side demo login, which cannot
// be verified here. These rules therefore allow public writes to content so the
// demo works end to end.
//
// FOR PRODUCTION: switch the admin to Firebase Auth and replace the `write`
// conditions below with `allow write: if request.auth != null;` (and lock the
// allowed uid/email), so only you can modify content.
service cloud.firestore {
  match /databases/{database}/documents {

    // Public content collections — anyone can read; demo allows write.
    match /blogs/{id}        { allow read: if true; allow write: if true; }
    match /projects/{id}     { allow read: if true; allow write: if true; }
    match /testimonials/{id} { allow read: if true; allow write: if true; }
    match /services/{id}     { allow read: if true; allow write: if true; }

    // Site settings (resume URL, etc.)
    match /settings/{id}     { allow read: if true; allow write: if true; }

    // First-party analytics — anyone may log a view; reads power the dashboard.
    match /analytics_events/{id} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }
  }
}
