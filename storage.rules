rules_version = '2';

// ⚠️ DEMO RULES — public read, and public write for the admin demo (uploads of
// project images and the resume PDF). For production, gate writes behind
// Firebase Auth: `allow write: if request.auth != null;`
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
